# ========================================
# WhatsMass - Variaveis de Ambiente
# ========================================

# Ambiente
NODE_ENV=development

# Base Path (apenas para desenvolvimento com proxy)
# Deixe vazio para producao na Vercel
NEXT_PUBLIC_BASE_PATH=/proxy/3001

# ========================================
# Evolution API (WhatsApp)
# ========================================
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua-api-key-aqui
EVOLUTION_INSTANCE_NAME=whatsmass

# ========================================
# Banco de Dados
# ========================================

# Desenvolvimento Local (SQLite)
DATABASE_URL=file:./prisma/dev.db

# Producao (Turso - SQLite Edge)
# Crie uma conta em https://turso.tech e obtenha as credenciais
# TURSO_DATABASE_URL=libsql://seu-banco.turso.io
# TURSO_AUTH_TOKEN=seu-token-aqui

# ========================================
# Configuracoes Opcionais
# ========================================

# Rate Limiting (ms)
DEFAULT_DELAY_MIN=30000
DEFAULT_DELAY_MAX=60000
DAILY_MESSAGE_LIMIT=200
HOURLY_MESSAGE_LIMIT=30
